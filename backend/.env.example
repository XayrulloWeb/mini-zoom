# === ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ ===

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/zoom_db?schema=public"

# JWT secret для подписи токенов (минимум 32 символа)
JWT_SECRET="your-super-secret-jwt-key-change-me"

# JWT refresh secret (минимум 32 символа)
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me"

# LiveKit credentials
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
LIVEKIT_URL="wss://your-livekit-server.com"

# === ОПЦИОНАЛЬНЫЕ ===

# Порт сервера (по умолчанию 3000)
PORT=3000

# Разрешённый origin для CORS (по умолчанию http://localhost:3001)
FRONTEND_URL="http://localhost:3001"

# Пропустить проверку подписи LiveKit webhook (только для разработки!)
LIVEKIT_WEBHOOK_SKIP_AUTH="true"
